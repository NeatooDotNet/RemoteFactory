@inherits LayoutComponentBase
@implements IDisposable
@using Neatoo.RemoteFactory
@inject ISnackbar Snackbar
@inject IFactoryEventRelay Relay

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h5" Class="ml-3">Person App</MudText>
        <MudSpacer />
    </MudAppBar>
    <MudMainContent Class="pt-16 px-4">
        <MudContainer MaxWidth="MaxWidth.Large" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private PersonEventHandler? _eventHandler;

    protected override void OnInitialized()
    {
        _eventHandler = new PersonEventHandler(Snackbar, Relay);
    }

    public void Dispose()
    {
        _eventHandler?.Dispose();
    }
}
